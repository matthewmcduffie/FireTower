<UserControl x:Class="FireTower.Tray.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource HeadlineTextStyle}" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Monitoring" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Pause Monitoring" Margin="0,0,8,0" Command="{Binding PauseMonitoringCommand}"/>
                    <Button Content="Resume Monitoring" Margin="0,0,8,0" Command="{Binding ResumeMonitoringCommand}"/>
                </StackPanel>

                <TextBlock Text="Tray Preferences" FontWeight="SemiBold" Margin="0,12,0,8"/>
                <CheckBox Content="Launch at login" IsChecked="{Binding LaunchAtLogin}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Theme:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="120" SelectedItem="{Binding Theme}">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>
                </StackPanel>
                <Button Content="Save Preferences" HorizontalAlignment="Left" Margin="0,8,0,0" Command="{Binding SaveTrayPreferencesCommand}"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource HealthyBrush}" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CriticalBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Reload" Margin="0,0,8,0" Command="{Binding ReloadConfigurationCommand}"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveConfigurationCommand}"/>
                    </StackPanel>
                    <TextBlock Text="Configuration (JSON)" FontWeight="SemiBold"/>
                </DockPanel>
                <TextBox Text="{Binding ConfigurationJson, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="{StaticResource MonoFontFamily}"
                         TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
