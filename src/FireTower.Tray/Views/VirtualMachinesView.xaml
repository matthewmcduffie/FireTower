<UserControl x:Class="FireTower.Tray.Views.VirtualMachinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}"/>
            <TextBlock Text="Virtual Machines" Style="{StaticResource HeadlineTextStyle}"/>
        </DockPanel>

        <!-- VM list — read-only, no cell edit mode, click always reaches the row -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,0">
            <DataGrid ItemsSource="{Binding VirtualMachines}"
                      SelectedItem="{Binding SelectedVirtualMachine}"
                      BorderThickness="0"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"        Binding="{Binding Name}"           Width="180"/>
                    <DataGridTextColumn Header="Provider"    Binding="{Binding ProviderId}"      Width="90"/>
                    <DataGridTextColumn Header="Power State" Binding="{Binding PowerState}"      Width="100"/>
                    <DataGridTextColumn Header="Health"      Binding="{Binding Health}"          Width="90"/>
                    <DataGridTextColumn Header="Recovery"    Binding="{Binding RecoveryState}"   Width="90"/>
                    <DataGridTextColumn Header="Restarts"    Binding="{Binding RestartCount}"    Width="70"/>
                    <DataGridTextColumn Header="Last Check"  Binding="{Binding LastHealthCheck}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!--
            Action panel — buttons operate on SelectedVirtualMachine.
            AsyncRelayCommand<VirtualMachineDto>.CanExecute(null) returns false so the
            buttons are automatically disabled while nothing is selected.
        -->
        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Context label: shows hint when nothing selected, VM details when selected -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Select a virtual machine above to take action on it."
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Visibility="{Binding SelectedVirtualMachine, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=Invert}"/>
                    <TextBlock Text="{Binding SelectedVirtualMachine.Name, StringFormat='Selected: {0}'}"
                               FontWeight="SemiBold"
                               Visibility="{Binding SelectedVirtualMachine, Converter={StaticResource NullToCollapsedConverter}}"/>
                    <TextBlock Text="{Binding SelectedVirtualMachine.PowerState, StringFormat='Power: {0}'}"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               FontSize="11"
                               Visibility="{Binding SelectedVirtualMachine, Converter={StaticResource NullToCollapsedConverter}}"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Start"
                            Margin="4,0,0,0"
                            Command="{Binding StartCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"/>
                    <Button Content="Stop"
                            Margin="4,0,0,0"
                            Command="{Binding StopCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"/>
                    <Button Content="Restart"
                            Margin="4,0,0,0"
                            Command="{Binding RestartCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"/>
                    <Button Content="Force Restart"
                            Margin="4,0,0,0"
                            Command="{Binding ForceRestartCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"/>
                    <Button Content="Enable Monitoring"
                            Margin="12,0,0,0"
                            Command="{Binding EnableMonitoringCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"/>
                    <Button Content="Disable Monitoring"
                            Margin="4,0,0,0"
                            Command="{Binding DisableMonitoringCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"/>
                    <Button Content="Remove"
                            Margin="16,0,0,0"
                            Command="{Binding RemoveCommand}"
                            CommandParameter="{Binding SelectedVirtualMachine}"
                            ToolTip="Remove this VM from monitoring"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
