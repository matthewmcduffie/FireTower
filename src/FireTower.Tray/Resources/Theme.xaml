<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Palette and density derived from guide/kinetic_watchdog/DESIGN.md so FireTower's
        WPF chrome mirrors the visual direction of the mockups (colors/spacing/typography
        only — see AGENTS.md for what may and may not be reused from those references).
    -->

    <Color x:Key="ColorSurfaceLowest">#0B0E15</Color>
    <Color x:Key="ColorSurfaceLow">#191B23</Color>
    <Color x:Key="ColorSurface">#10131A</Color>
    <Color x:Key="ColorSurfaceContainer">#1D2027</Color>
    <Color x:Key="ColorSurfaceContainerHigh">#272A31</Color>
    <Color x:Key="ColorOutline">#424754</Color>
    <Color x:Key="ColorOnSurface">#E1E2EC</Color>
    <Color x:Key="ColorOnSurfaceVariant">#C2C6D6</Color>
    <Color x:Key="ColorPrimary">#ADC6FF</Color>
    <Color x:Key="ColorPrimaryContainer">#4D8EFF</Color>
    <Color x:Key="ColorHealthy">#3DDC84</Color>
    <Color x:Key="ColorWarning">#FFB74D</Color>
    <Color x:Key="ColorCritical">#FF6B6B</Color>
    <Color x:Key="ColorRecovering">#4D8EFF</Color>
    <Color x:Key="ColorDisabled">#8C909F</Color>

    <SolidColorBrush x:Key="SurfaceLowestBrush" Color="{StaticResource ColorSurfaceLowest}"/>
    <SolidColorBrush x:Key="SurfaceLowBrush" Color="{StaticResource ColorSurfaceLow}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource ColorSurfaceContainer}"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource ColorSurfaceContainerHigh}"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource ColorOutline}"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource ColorOnSurface}"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource ColorOnSurfaceVariant}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource ColorPrimaryContainer}"/>
    <SolidColorBrush x:Key="HealthyBrush" Color="{StaticResource ColorHealthy}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource ColorCritical}"/>
    <SolidColorBrush x:Key="RecoveringBrush" Color="{StaticResource ColorRecovering}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource ColorDisabled}"/>

    <FontFamily x:Key="UiFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Consolas</FontFamily>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="HeadlineTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource PrimaryContainerBrush}"/>
        <Setter Property="Foreground" Value="#00285D"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="NavButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="GroupName" Value="Navigation"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="3">
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceLowBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource SurfaceContainerBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceLowBrush}"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="RowHeight" Value="32"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource SurfaceLowBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceLowestBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="CaretBrush" Value="{StaticResource OnSurfaceBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceLowestBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
    </Style>

    <!--
        ComboBox dropdown popup items.  The popup DOES inherit Application resources,
        so these implicit styles are sufficient to colour the dark drop-down list.
    -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background"          Value="{StaticResource SurfaceContainerBrush}"/>
        <Setter Property="Foreground"          Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="Padding"             Value="8,5"/>
        <Setter Property="FontFamily"          Value="{StaticResource UiFontFamily}"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryContainerBrush}"/>
                <Setter Property="Foreground" Value="#00285D"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- CheckBox ticked in dark theme -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
