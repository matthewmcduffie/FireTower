<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <Package Name="FireTower"
             Manufacturer="Matthew McDuffie"
             Version="$(ProductVersion)"
             UpgradeCode="4C1B2A3D-5E6F-7A8B-9C0D-E1F2A3B4C5D6"
             ProductCode="*"
             Language="1033"
             Scope="perMachine">

        <MajorUpgrade DowngradeErrorMessage="A newer version of FireTower is already installed."/>
        <MediaTemplate EmbedCab="yes"/>

        <!--
            "Launch FireTower" checkbox on the installer finish page.
            Checked by default so first-time users see the app immediately.
        -->
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX"     Value="1"/>
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch FireTower"/>
        <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER"/>

        <!--
            Launch the tray app when the user clicks Finish.
            Runs in the UI process context (the logged-in user, not elevated)
            so the window appears on the desktop rather than the secure desktop.
        -->
        <CustomAction Id="CA_LaunchTray"
                      FileRef="F_TrayExe"
                      ExeCommand=""
                      Execute="immediate"
                      Return="asyncNoWait"/>

        <InstallUISequence>
            <Custom Action="CA_LaunchTray" OnExit="success"
                    Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed AND NOT REMOVE"/>
        </InstallUISequence>

        <!-- ── Directories ──────────────────────────────────────────────── -->

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="FireTower"/>
        </StandardDirectory>

        <StandardDirectory Id="CommonAppDataFolder">
            <Directory Id="PROGRAMDATAFOLDER" Name="FireTower">
                <Directory Id="CONFIGDIR"  Name="config"/>
                <Directory Id="LOGSDIR"    Name="logs"/>
                <Directory Id="DATADIR"    Name="data"/>
                <Directory Id="BACKUPSDIR" Name="backups"/>
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="STARTMENU" Name="FireTower"/>
        </StandardDirectory>

        <!-- ── Service exe + Windows Service registration ───────────────── -->

        <Component Id="C_ServiceExe" Directory="INSTALLFOLDER" Guid="*">
            <File Id="F_ServiceExe"
                  Name="FireTower.Service.exe"
                  Source="$(ServiceExe)"
                  KeyPath="yes"/>

            <ServiceInstall
                Id="FireTowerService"
                Name="FireTower"
                DisplayName="FireTower VM Watchdog"
                Description="Monitors and automatically recovers VirtualBox virtual machines."
                Type="ownProcess"
                Start="auto"
                ErrorControl="normal"
                Account="LocalSystem"/>

            <!--
                Wait="no": the installer signals the service to start and moves on
                without blocking until the service reports "Running".  On a cold start
                the service initialises VirtualBox and SQLite, which can exceed the
                30-second Windows Service startup timeout on slower hardware.
            -->
            <ServiceControl
                Id="FireTowerServiceControl"
                Name="FireTower"
                Start="install"
                Stop="both"
                Remove="uninstall"
                Wait="no"/>
        </Component>

        <!-- ── Tray exe (all other app files come from CG_AppFiles) ─────── -->

        <Component Id="C_TrayExe" Directory="INSTALLFOLDER" Guid="*">
            <File Id="F_TrayExe"
                  Name="FireTower.Tray.exe"
                  Source="$(TrayExe)"
                  KeyPath="yes"/>
        </Component>

        <!-- ── All remaining published files (DLLs, configs, etc.) ──────── -->

        <!--  CG_AppFiles is generated at build time by HarvestDirectory in
              FireTower.Installer.wixproj from the publish output folder.       -->

        <!-- ── ProgramData directories ───────────────────────────────────── -->

        <!--
            The service runs as LocalSystem and calls EnsureDirectoriesExist() on startup,
            which creates these folders with Windows-default ACLs (LocalSystem full control,
            Authenticated Users read). No explicit Permission element is needed and setting
            one here causes MsiLockPermissionsEx failures on some Windows configurations.
        -->
        <Component Id="C_ConfigDir"  Directory="CONFIGDIR"  Guid="AA7B2C3D-E4F5-6A7B-8C9D-E0F1A2B3C4D5">
            <CreateFolder/>
        </Component>
        <Component Id="C_LogsDir"    Directory="LOGSDIR"    Guid="BB8C3D4E-F5A6-7B8C-9D0E-F1A2B3C4D5E6">
            <CreateFolder/>
        </Component>
        <Component Id="C_DataDir"    Directory="DATADIR"    Guid="CC9D4E5F-A6B7-8C9D-0E1F-A2B3C4D5E6F7">
            <CreateFolder/>
        </Component>
        <Component Id="C_BackupsDir" Directory="BACKUPSDIR" Guid="DD0E5F6A-B7C8-9D0E-1F2A-B3C4D5E6F7A8">
            <CreateFolder/>
        </Component>

        <!-- ── Start Menu shortcut ──────────────────────────────────────── -->

        <Component Id="C_StartMenuShortcut" Directory="STARTMENU" Guid="*">
            <Shortcut Id="S_TrayShortcut"
                      Name="FireTower"
                      Description="FireTower VM Watchdog"
                      Target="[INSTALLFOLDER]FireTower.Tray.exe"
                      WorkingDirectory="INSTALLFOLDER"/>
            <RemoveFolder Id="RF_StartMenu" Directory="STARTMENU" On="uninstall"/>
            <RegistryValue Root="HKCU" Key="Software\FireTower"
                           Name="StartMenuInstalled" Type="integer" Value="1" KeyPath="yes"/>
        </Component>

        <!-- ── Feature ──────────────────────────────────────────────────── -->

        <Feature Id="F_Complete" Title="FireTower" Level="1">
            <ComponentRef      Id="C_ServiceExe"/>
            <ComponentRef      Id="C_TrayExe"/>
            <ComponentGroupRef Id="CG_AppFiles"/>
            <ComponentRef      Id="C_ConfigDir"/>
            <ComponentRef      Id="C_LogsDir"/>
            <ComponentRef      Id="C_DataDir"/>
            <ComponentRef      Id="C_BackupsDir"/>
            <ComponentRef      Id="C_StartMenuShortcut"/>
        </Feature>

    </Package>
</Wix>
