<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ColorSurface">#10131A</Color>
    <Color x:Key="ColorSurfaceLow">#191B23</Color>
    <Color x:Key="ColorSurfaceContainer">#1D2027</Color>
    <Color x:Key="ColorSurfaceContainerHigh">#272A31</Color>
    <Color x:Key="ColorOutline">#424754</Color>
    <Color x:Key="ColorOnSurface">#E1E2EC</Color>
    <Color x:Key="ColorOnSurfaceVariant">#C2C6D6</Color>
    <Color x:Key="ColorPrimary">#ADC6FF</Color>

    <SolidColorBrush x:Key="SurfaceBrush"              Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="SurfaceLowBrush"           Color="{StaticResource ColorSurfaceLow}"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush"     Color="{StaticResource ColorSurfaceContainer}"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource ColorSurfaceContainerHigh}"/>
    <SolidColorBrush x:Key="OutlineBrush"              Color="{StaticResource ColorOutline}"/>
    <SolidColorBrush x:Key="OnSurfaceBrush"            Color="{StaticResource ColorOnSurface}"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush"     Color="{StaticResource ColorOnSurfaceVariant}"/>
    <SolidColorBrush x:Key="PrimaryBrush"              Color="{StaticResource ColorPrimary}"/>

    <FontFamily x:Key="UiFont">Segoe UI</FontFamily>

    <Style TargetType="Window">
        <Setter Property="Background"   Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground"   Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="FontFamily"   Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"     Value="13"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
    </Style>

    <Style x:Key="CaptionStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
        <Setter Property="FontSize"   Value="11"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource SurfaceContainerHighBrush}"/>
        <Setter Property="Foreground"   Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"      Value="12,5"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="#4D8EFF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background"       Value="#0B0E15"/>
        <Setter Property="Foreground"       Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="6,4"/>
        <Setter Property="CaretBrush"       Value="{StaticResource OnSurfaceBrush}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
    </Style>

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource SurfaceContainerBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource OutlineBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="4"/>
        <Setter Property="Padding"          Value="14"/>
    </Style>

</ResourceDictionary>
