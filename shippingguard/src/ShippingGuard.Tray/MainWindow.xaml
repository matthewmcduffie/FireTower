<Window x:Class="ShippingGuard.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ShippingGuard.Tray.Views"
        Title="ShippingGuard" Height="520" Width="640"
        MinHeight="300" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <views:AppListView/>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{StaticResource SurfaceLowBrush}"
                BorderBrush="{StaticResource OutlineBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,6">
                <Button DockPanel.Dock="Right" Content="+ Add Application"
                        Click="AddApp_Click" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding AgentStatus}" VerticalAlignment="Center"
                           Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
